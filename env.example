# Copie para .env e preencha. App da Twitch: https://dev.twitch.tv/console/apps
TWITCH_CHANNEL=          # login do canal (ex: iklobato), nao o id numerico
TWITCH_CLIENT_ID=        # Client-ID do app
TWITCH_USER_TOKEN=       # user OAuth token (sem "Bearer"); scopes: moderator:read:followers, channel:read:redemptions

# Transcricao (opcional)
WHISPER_MODEL=small          # base/small/medium/large-v3
WHISPER_LANG=pt
TRANSCRIBE_CHUNK_SECONDS=20
