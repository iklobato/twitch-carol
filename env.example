# Copy this file to .env and fill it in.
#
# Twitch application (https://dev.twitch.tv/console/apps) and identities.
# Use NUMERIC user ids, not channel names. Get them from the Twitch API or a
# tool like https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_ID=          # user id of the bot account
TWITCH_OWNER_ID=        # user id of your channel (broadcaster)
TWITCH_PREFIX=!
TWITCH_THANK_IN_CHAT=false   # set true to post a thank-you in chat (needs user:write:chat)

# LivePix OAuth2 client credentials (https://docs.livepix.gg/api).
LIVEPIX_CLIENT_ID=
LIVEPIX_CLIENT_SECRET=
# Any random string. Put the same value in your LivePix webhook URL:
#   https://YOUR_PUBLIC_HOST/webhook/livepix/<this-secret>
LIVEPIX_WEBHOOK_SECRET=change-me

# Web server hosting the overlay + webhook.
HOST=127.0.0.1
PORT=8080

# NSFW filter.
NSFW_WORDLIST_PATH=nsfw_words_pt.txt
NSFW_DELETE_MESSAGE=true
NSFW_TIMEOUT_SECONDS=0   # >0 also times out the author (needs moderator:manage:banned_users)
