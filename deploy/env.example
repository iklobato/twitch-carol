# Copy to .env at the repo root. (Named env.example because tooling here
# blocks writing .env* files.)

# Twitch app credentials (dev.twitch.tv console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Secret used to sign/verify EventSub webhook payloads
TWITCH_EVENTSUB_SECRET=

# Public URL where Twitch can reach the API (webhooks, OAuth redirect).
# Local dev: http://localhost:8080 and register http://localhost:8080/auth/callback
# as an OAuth redirect URL in the Twitch dev console.
PUBLIC_BASE_URL=https://example.com

DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/app
VALKEY_URL=redis://valkey:6379/0

# DigitalOcean Spaces (S3-compatible) for audio storage
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=

# Fernet key for OAuth token encryption at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Transcription
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Local LLM (llama.cpp)
LLM_BACKEND=local
LLM_GGUF_PATH=
LLM_MAX_INPUT_TOKENS=30000
LLM_MAX_OUTPUT_TOKENS=3000

# 1 = fake sources via scripts/simulate_stream.py instead of real Twitch.
# deploy/sim.env defaults this to 1 for local compose; set 0 here for real capture.
SIMULATION=0

# Where audio segments go when Spaces is not configured (container path)
AUDIO_LOCAL_DIR=/data/audio

# Twitch logins allowed to impersonate other channels (support/debug).
# Comma-separated, case-insensitive. Empty = nobody can impersonate.
ADMIN_LOGINS=

# Sentry error reporting. Empty disables it. DSN from the streamintel project
# in Sentry (Settings -> Projects -> streamintel -> Client Keys).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
