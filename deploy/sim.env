# Dev/simulation defaults, loaded BEFORE ../.env so any value you set in the
# root .env overrides these. Not a secret: this literal is shared with
# scripts/simulate_stream.py for local webhook signing only.
TWITCH_EVENTSUB_SECRET=dev-simulation-secret
SIMULATION=1
# tiny keeps local/CI transcription fast; prod uses the "small" default
WHISPER_MODEL=tiny
# small GGUF for local analysis; prod points at a 3B-8B class model
LLM_GGUF_PATH=/data/models/qwen2.5-1.5b-instruct-q4_k_m.gguf
